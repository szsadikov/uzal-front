    "@visx/pattern": "3.13.0-alpha.0",
    "apexcharts": "5.3.5",
    "axios": "1.11.0",
    "classnames": "2.5.1",
    "d3-dsv": "3.0.1",
    "d3-fetch": "3.0.1",
    "d3-scale": "4.0.2",
    "dayjs": "1.11.13",
    "dom-to-image-more": "3.7.1",
    "exceljs": "4.4.0",
    "file-saver": "2.0.5",
    "formik": "2.4.6",
    "framer-motion": "12.23.9",
    "history": "5.3.0",
    "html-react-parser": "5.2.6",
    "i18next": "25.3.2",
    "jspdf": "3.0.3",
    "lodash": "4.17.21",
    "miragejs": "0.1.48",
    "react": "19.1.0",
    "react-apexcharts": "1.7.0",
    "react-custom-scrollbars-4": "4.5.1",
