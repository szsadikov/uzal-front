    "tailwindcss": "~4.1.11",
    "typescript": "~5.8.3",
    "typescript-eslint": "~8.38.0",
    "vite": "~7.1.7",
    "vite-plugin-dynamic-import": "~1.6.0",
    "vite-plugin-eslint2": "~5.0.4"
  },
  "overrides": {
