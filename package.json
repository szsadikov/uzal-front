    "react-redux": "9.2.0",
    "react-router-dom": "7.7.1",
    "react-scroll": "1.9.3",
    "react-select": "5.10.2",
    "react-simple-maps": "3.0.0",
    "react-syntax-highlighter": "15.6.1",
    "react-toastify": "11.0.5",
